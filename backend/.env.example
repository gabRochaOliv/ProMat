# ================================
# CONFIGURAÇÃO DO SERVIDOR
# ================================
PORT=3001
NODE_ENV=development

# ================================
# PROVEDOR DE IA (OBRIGATÓRIO)
# ================================
# Provedor atual: openai | gemini | anthropic
AI_PROVIDER=openai

# Chave da API OpenAI
OPENAI_API_KEY=sk-...

# Chave da API Google Gemini (alternativa)
# GEMINI_API_KEY=AIza...

# ================================
# CONTROLE DE CUSTOS
# ================================
# Máximo de exercícios por geração (limite de segurança)
MAX_EXERCISES=20

# Máximo de tokens por resposta
MAX_TOKENS=2000

# Modelo a utilizar (mais barato: gpt-4o-mini)
AI_MODEL=gpt-4o-mini

# ================================
# RATE LIMITING
# ================================
# Requisições por janela de tempo (por IP)
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=900000

# ================================
# CORS (Frontend)
# ================================
FRONTEND_URL=http://localhost:5500

# SUPABASE CONFIG (Etapa 1: Fundação)
# URL do projeto Supabase
SUPABASE_URL=https://xxxxxxxx.supabase.co
# Anon key (encontrada em Settings -> API)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Service role key (encontrada em Settings -> API - NUNCA EXPOR)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
