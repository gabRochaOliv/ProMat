{
  "version": 2,
  "name": "promat",
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    },
    {
      "src": "landing/**",
      "use": "@vercel/static"
    },
    {
      "src": "auth/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/landing/?$",
      "dest": "landing/index.html"
    },
    {
      "src": "/landing/(.*)",
      "dest": "landing/$1"
    },
    {
      "src": "/auth/?$",
      "dest": "auth/index.html"
    },
    {
      "src": "/auth/(.*)",
      "dest": "auth/$1"
    },
    {
      "src": "/(assets|css|js)/(.*)",
      "dest": "frontend/$1/$2"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/index.html"
    }
  ]
}